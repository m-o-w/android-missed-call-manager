<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Detect call state and read the number from the call log -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Send the forwarding SMS silently in the background -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Re-arm after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Status notifications (Android 13+ requires runtime grant) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Used to prompt the user to exempt the app from battery optimization -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Dual-SIM: read which subscriptions exist so the user can pick the sending SIM -->
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <application
        android:name=".ForwarderApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MissedCallForwarder">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MissedCallForwarder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fires on every phone-state change; we infer missed calls from transitions -->
        <receiver
            android:name=".receiver.CallReceiver"
            android:exported="true"
            android:permission="android.permission.READ_PHONE_STATE">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Re-register intent after reboot (manifest receivers already survive reboot,
             this is belt-and-suspenders for OEMs and for any warm-up work) -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
